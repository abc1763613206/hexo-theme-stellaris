.tag-plugin.ds-music
    max-width: 80%
    margin: 1em auto
    .aplayer
        font-family: $ff-body
        border-radius: $border-card
        box-shadow: $boxshadow-card-float
        z-index 1
        height: 100%
        background: var(--card)

        // FOUC/闪屏兜底：APlayer.min.css 走异步加载时，先锁定封面尺寸，避免 cover 首次渲染被撑到很大。
        // APlayer CSS 加载完成后会覆盖/补全其它样式，这里只做最小必要约束。
        .aplayer-pic
            width: 90px
            height: 90px
            flex: 0 0 90px
            overflow: hidden
            background-size: cover
            background-position: center
        .aplayer-pic img
            width: 100%
            height: 100%
            display: block
            object-fit: cover

        .aplayer-info .aplayer-music 
            .aplayer-title
                color: var(--text-p1)
            .aplayer-author
                color: var(--text-p2)
        .aplayer-lrc 
            p
                color: var(--text-p2)
                text-align: center
                display: var(--lrc-display)
        .aplayer-lrc:before
            background: linear-gradient(180deg,var(--card) 0,hsla(0,0%,100%,0));
        .aplayer-lrc:after
            background: linear-gradient(0,var(--card) 0,hsla(0,0%,100%,0));
        .aplayer-time
            .aplayer-icon
                color: var(--text-p2)
            
        